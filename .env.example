# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/contact_share?schema=public"

# JWT Secrets (CHANGE IN PRODUCTION!)
JWT_ACCESS_SECRET="your-super-secret-access-key-change-me-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-me-in-production"

# JWT Expiration
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"

# Application
APP_BASE_URL="http://localhost:3000"

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS="*"

# Test Database (for testing)
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/contact_share_test?schema=public"
